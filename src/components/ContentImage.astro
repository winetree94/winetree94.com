---

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  src: ImageMetadata;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  widths?: number[];
  sizes?: string;
};

const {
  src,
  alt,
  class: className,
  loading = "lazy",
  widths,
  sizes,
} = Astro.props;

const isPassthroughFormat = src.format === "gif" || src.format === "svg";
---

{
  isPassthroughFormat ? (
    <img
      class={className}
      src={src.src}
      alt={alt}
      width={src.width}
      height={src.height}
      loading={loading}
    />
  ) : (
    <Image
      class={className}
      src={src}
      alt={alt}
      loading={loading}
      widths={widths}
      sizes={sizes}
    />
  )
}
