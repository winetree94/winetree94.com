---
import { Image } from "astro:assets";
import { badgeIcons } from "@/assets/badges";
import { getTranslation } from "@/i18n/utils";
import type { SupportedLanguageCodes } from "@/lib/language";
import IndentLine from "../IndentLine.astro";

type Props = {
  lang: SupportedLanguageCodes;
};

const t = getTranslation(Astro.props.lang);

const badges = [
  { label: "Typescript", slug: "typescript" },
  { label: "Angular", slug: "angular" },
  { label: "React", slug: "react" },
  { label: "Webpack", slug: "webpack" },
  { label: "Jest", slug: "jest" },
  { label: "Aws", slug: "aws" },
  { label: "Docker", slug: "docker" },
] as const;
---

<h3 id="qualifications" class="text-2xl font-bold">
  {t("about.qualifications")}
</h3>
<IndentLine>
  <div>
    <p class="mt-2">
      {t("about.qualifications.description")}
    </p>
  </div>
  <div class="mt-8">
    <h3 class="text-2xl">{t("about.qualifications.frontend")}</h3>
    <ul class="mt-2 list-inside list-disc">
      {
        [1, 2, 3, 4, 5, 6, 7].map((idx) => (
          <li class="ml-6 list-outside">
            {t(`about.qualifications.frontend.${idx}`)}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="mt-8">
    <h3 class="text-2xl">{t("about.qualifications.others")}</h3>
    <ul class="mt-2 list-inside list-disc">
      {
        [1, 2, 3].map((idx) => (
          <li class="ml-6 list-outside">
            {t(`about.qualifications.others.${idx}`)}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="mt-8">
    <h3 class="text-2xl">
      {t("about.qualifications.key_technology_keywords")}
    </h3>
    <div class="mt-2 flex flex-wrap gap-2">
      {
        badges.map(({ label, slug }) => (
          <div class="badge badge-soft flex gap-0">
            <Image
              class="mr-2 h-4 w-4"
              src={badgeIcons[slug]}
              alt={`${label} favicon`}
              width={16}
              height={16}
            />
            {label}
          </div>
        ))
      }
    </div>
  </div>
</IndentLine>
