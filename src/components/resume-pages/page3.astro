---
import WorkExperience from "@/components/resume/WorkExperience.astro";
import { WORK_EXPERIENCE } from "@/libs/constants";
import type { SupportedLanguageCodes } from "@/lib/language";

type Props = {
  lang: SupportedLanguageCodes;
};
---

<div class="flex w-full flex-col justify-start">
  <WorkExperience
    lang={Astro.props.lang}
    indentEnd={true}
    workExperience={WORK_EXPERIENCE.slice(1, 3)}
  />
</div>
