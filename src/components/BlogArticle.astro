---
import BaseHead from "@/components/BaseHead.astro";
import BlogHeader from "@/components/BlogHeader.astro";
import Footer from "@/components/Footer.astro";
import GhostPost from "@/components/GhostPost.astro";
import ContentImage from "@/components/ContentImage.astro";
import type { ImageMetadata } from "astro";
import type { SupportedLanguageCodes } from "@/lib/language";
import type { ArticleEntry, PageEntry } from "@/lib/content";
import {
  buildAlternativeLanguageHref,
  getAlternativeLanguageLabel,
} from "@/lib/blog-article";
import TextDate from "./TextDate.astro";
import Gtm from "./Gtm.astro";
import ArticleAuthor from "./ArticleAuthor.astro";
import { getTranslation } from "@/i18n/utils";

type Props = {
  lang: SupportedLanguageCodes;
  entry: ArticleEntry | PageEntry;
  alternativeEntries: Array<
    | {
        lang: SupportedLanguageCodes;
      }
    | ArticleEntry
    | PageEntry
  >;
  slug: string;
  usePublishedDate?: boolean;
  useAuthor?: boolean;
  useComments?: boolean;
};

type RenderableEntryData = {
  title: string;
  excerpt?: string;
  featureImage?: ImageMetadata;
  publishedAt?: string;
};

const props = Astro.props as Props;
const { entry } = props;
const entryData = entry.data as RenderableEntryData;
const alternativeEntries = props.alternativeEntries
  .map((alternativeEntry) => {
    const lang = (
      "lang" in alternativeEntry
        ? alternativeEntry.lang
        : ((alternativeEntry.data as { lang: SupportedLanguageCodes }).lang as SupportedLanguageCodes)
    ) as SupportedLanguageCodes;

    return { lang };
  })
  .filter((alternativeEntry) => alternativeEntry.lang !== props.lang);
const publishedAt =
  typeof entryData.publishedAt === "string" ? entryData.publishedAt : undefined;
const t = getTranslation(props.lang);
---

<html lang={props.lang}>
  <head>
    <BaseHead
      title={entryData.title}
      description={entryData.excerpt || entryData.title}
      ogImageUrl={entryData.featureImage?.src}
      lang={props.lang}
    />
  </head>

  <body>
    <Gtm />
    <BlogHeader lang={props.lang} />
    <main class="w-full max-w-full">
      <article>
        {entryData.featureImage && (
          <ContentImage
            class="mx-auto aspect-video w-full max-h-80 object-cover"
            src={entryData.featureImage as ImageMetadata}
            alt={entryData.title}
            loading="eager"
            widths={[720, 1280, 1600]}
            sizes="100vw"
          />
        )}
        <div class="m-auto max-w-[720px] px-4">
          <div class:list={["mt-4 flex flex-col py-4 text-center"]}>
            <h1 class="text-4xl">{entryData.title}</h1>
            {props.usePublishedDate && publishedAt && (
              <div class="mt-2">
                <TextDate lang={props.lang} date={publishedAt} />
              </div>
            )}
            {alternativeEntries.length > 0 && (
              <div class="mt-8 flex items-center justify-end text-sm">
                {t("article.alternative-language-available")}
                <div class="ml-1 flex gap-2">
                  {alternativeEntries.map((alternativeEntry) => (
                      <a
                        class:list={["badge badge-neutral badge-ghost text-sm"]}
                        href={buildAlternativeLanguageHref(
                          Astro.url.pathname,
                          props.lang,
                          alternativeEntry.lang,
                        )}
                      >
                        {getAlternativeLanguageLabel(alternativeEntry.lang)}
                      </a>
                    ))}
                  </div>
              </div>
            )}
            <div class="divider"></div>
          </div>
          <GhostPost>
            <slot />
          </GhostPost>
          {props.useAuthor && (
            <div class="mt-12">
              <ArticleAuthor lang={props.lang} />
            </div>
          )}
          {
            props.useComments && (
              <div class="mt-16">
                <script
                  is:inline
                  class="discus"
                  src="https://giscus.app/client.js"
                  data-repo="winetree94/winetree94.com"
                  data-repo-id="R_kgDOMQZteg"
                  data-category="Announcements"
                  data-category-id="DIC_kwDOMQZtes4Cg0or"
                  data-mapping="specific"
                  data-term={props.slug}
                  data-strict="1"
                  data-reactions-enabled="1"
                  data-emit-metadata="0"
                  data-input-position="bottom"
                  data-theme="dark"
                  data-lang={props.lang}
                  crossorigin="anonymous"
                  async
                />
                <script>
                  import { setupGiscusThemeSync } from "@/lib/blog-article";

                  setupGiscusThemeSync();
                </script>
              </div>
            )
          }
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
