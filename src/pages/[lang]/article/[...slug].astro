---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BlogArticle from "@/components/BlogArticle.astro";
import { getAllArticles, getArticleAlternatives } from "@/lib/content";

export const getStaticPaths = (async () => {
  const articles = (await getAllArticles()) as any[];

  return Promise.all(
    articles.map(async (entry: any) => ({
      params: {
        lang: entry.data.lang,
        slug: entry.data.routeSlug,
      },
      props: {
        entry,
        alternativeEntries: await getArticleAlternatives(
          entry.data.translationKey,
          entry.data.lang,
        ),
      },
    })),
  );
}) satisfies GetStaticPaths;

const { entry, alternativeEntries } = Astro.props as any;
const { Content } = await render(entry);
---

<BlogArticle
  slug={entry.data.commentsTerm}
  lang={Astro.params.lang}
  entry={entry}
  alternativeEntries={alternativeEntries}
  usePublishedDate={true}
  useAuthor={true}
  useComments={true}
>
  <Content />
</BlogArticle>
