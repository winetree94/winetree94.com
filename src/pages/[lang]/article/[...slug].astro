---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import ArticleAuthor from "@/components/ArticleAuthor.astro";
import BlogArticle from "@/components/BlogArticle.astro";
import TextDate from "@/components/TextDate.astro";
import { type ArticleEntry, getAllArticles } from "@/lib/content";
import { LOCALE_INFO } from "@/lib/language";

type Props = {
  entry: ArticleEntry;
  alternativeLanguageLinks: Array<{
    href: string;
    label: string;
    lang: ArticleEntry["data"]["lang"];
  }>;
};

export const getStaticPaths = (async () => {
  const articles = await getAllArticles();

  return articles.map((entry) => ({
      params: {
        lang: entry.data.lang,
        slug: entry.data.routeSlug,
      },
      props: {
        entry,
        alternativeLanguageLinks: articles
          .filter((candidate) => {
            return (
              candidate.data.translationKey === entry.data.translationKey &&
              candidate.data.lang !== entry.data.lang
            );
          })
          .map((candidate) => ({
            href: `/${candidate.data.lang}/article/${candidate.data.routeSlug}/`,
            label: LOCALE_INFO[candidate.data.lang].nativeName,
            lang: candidate.data.lang,
          })),
      },
    }));
}) satisfies GetStaticPaths;

const { entry, alternativeLanguageLinks } = Astro.props as Props;
const { Content } = await render(entry);
---

<BlogArticle
  lang={Astro.params.lang}
  title={entry.data.title}
  description={entry.data.excerpt || entry.data.title}
  featureImage={entry.data.featureImage}
  alternativeLanguageLinks={alternativeLanguageLinks}
>
  <div slot="headerMeta" class="mt-2">
    <TextDate lang={Astro.params.lang} date={entry.data.publishedAt} />
  </div>
  <Content />
  <Fragment slot="afterContent">
    <div class="mt-12">
      <ArticleAuthor lang={Astro.params.lang} />
    </div>
    <div class="mt-16">
      <script
        is:inline
        class="discus"
        src="https://giscus.app/client.js"
        data-repo="winetree94/winetree94.com"
        data-repo-id="R_kgDOMQZteg"
        data-category="Announcements"
        data-category-id="DIC_kwDOMQZtes4Cg0or"
        data-mapping="specific"
        data-term={entry.data.commentsTerm}
        data-strict="1"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="dark"
        data-lang={Astro.params.lang}
        crossorigin="anonymous"
        async
      />
      <script>
        import { setupGiscusThemeSync } from "@/lib/blog-article";

        setupGiscusThemeSync();
      </script>
    </div>
  </Fragment>
</BlogArticle>
