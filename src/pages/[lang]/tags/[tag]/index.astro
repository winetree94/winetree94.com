---
import BaseHead from "@/components/BaseHead.astro";
import BlogHeader from "@/components/BlogHeader.astro";
import type { GetStaticPaths } from "astro";
import {
  SUPPORTED_LANGUAGES,
  type SupportedLanguageCodes,
} from "@/lib/language";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import Footer from "@/components/Footer.astro";
import ContentImage from "@/components/ContentImage.astro";
import TextDate from "@/components/TextDate.astro";
import { TRANSLATIONS } from "@/i18n";
import Gtm from "@/components/Gtm.astro";
import {
  getArticlesByTag,
  getTagPages,
  type ArticleEntry,
  type TagEntry,
} from "@/lib/content";

type Props = {
  tag: TagEntry;
  posts: ArticleEntry[];
};

export const getStaticPaths = (async () => {
  const tags = await getTagPages();
  const langs = Object.values(SUPPORTED_LANGUAGES);

  return Promise.all(
    langs.flatMap((lang) =>
      tags.map(async (tag) => ({
        params: {
          lang,
          tag: tag.data.slug,
        },
        props: {
          tag,
          posts: await getArticlesByTag(lang, tag.data.slug),
        },
      })),
    ),
  );
}) satisfies GetStaticPaths;
const { tag, posts } = Astro.props as Props;
const tagTranslation = tag.data.translations[Astro.params.lang];
const t = (key: string) => {
  return TRANSLATIONS[Astro.params.lang as SupportedLanguageCodes][key];
};
---

<!doctype html>
<html lang={Astro.params.lang}>
  <head>
    <BaseHead
      title={tagTranslation?.title || SITE_TITLE}
      description={tagTranslation?.description || SITE_DESCRIPTION}
      lang={Astro.params.lang}
    />
  </head>
  <body>
    <Gtm />
    <BlogHeader lang={Astro.params.lang} />
    <main class="mt-18 flex w-full justify-center">
      <article class="flex w-full max-w-[720px] flex-col px-4">
        {
          tagTranslation && (
            <div class="flex flex-col items-center justify-center gap-4">
              <h1 class="text-3xl whitespace-pre-line">{tagTranslation.title}</h1>
              <p class="text-lg whitespace-pre-line">{tagTranslation.description}</p>
            </div>
          )
        }
        {
          posts.length ? (
            <ul class="mt-8 flex list-none flex-wrap gap-8">
              {posts.map((post) => (
                <li class="w-full sm:w-[calc(50%-1rem)]">
                  <a
                    class="flex flex-col"
                    href={`/${Astro.params.lang}/article/${post.data.routeSlug}/`}
                  >
                    {post.data.featureImage && (
                      <ContentImage
                        class="aspect-video w-full rounded-xl object-cover"
                        src={post.data.featureImage}
                        alt={post.data.title}
                        loading="lazy"
                        widths={[360, 720]}
                        sizes="(min-width: 640px) 344px, 100vw"
                      />
                    )}
                    <h6 class="title mt-4">{post.data.title}</h6>
                    <p class="date">
                      <TextDate lang={Astro.params.lang} date={post.data.publishedAt} />
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <div class="flex justify-center">
              <p>{t("global.empty")}</p>
            </div>
          )
        }
      </article>
    </main>
    <Footer />
  </body>
</html>
