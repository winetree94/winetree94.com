---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BlogArticle from "@/components/BlogArticle.astro";
import {
  getAllPages,
  getPageAlternatives,
  type PageEntry,
} from "@/lib/content";

type Props = {
  entry: PageEntry;
  alternativeEntries: PageEntry[];
};

export const getStaticPaths = (async () => {
  const pages = await getAllPages();
  const aboutPages = pages.filter(
    (page) => page.data.routeSlug === "about",
  );

  return Promise.all(
    aboutPages.map(async (entry) => ({
      props: {
        entry,
        alternativeEntries: await getPageAlternatives(
          entry.data.translationKey,
          entry.data.lang,
        ),
      },
      params: {
        lang: entry.data.lang,
      },
    })),
  );
}) satisfies GetStaticPaths;

const { entry, alternativeEntries } = Astro.props as Props;
const { Content } = await render(entry);
---

<BlogArticle
  useAuthor={false}
  slug={entry.data.routeSlug}
  lang={Astro.params.lang}
  entry={entry}
  alternativeEntries={alternativeEntries}
>
  <Content />
</BlogArticle>
