---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BlogArticle from "@/components/BlogArticle.astro";
import { getAllPages, type PageEntry } from "@/lib/content";
import { LOCALE_INFO } from "@/lib/language";

type Props = {
  entry: PageEntry;
  alternativeLanguageLinks: Array<{
    href: string;
    label: string;
    lang: PageEntry["data"]["lang"];
  }>;
};

export const getStaticPaths = (async () => {
  const pages = await getAllPages();
  const aboutPages = pages.filter(
    (page) => page.data.routeSlug === "about",
  );

  return aboutPages.map((entry) => ({
      props: {
        entry,
        alternativeLanguageLinks: aboutPages
          .filter((candidate) => {
            return (
              candidate.data.translationKey === entry.data.translationKey &&
              candidate.data.lang !== entry.data.lang
            );
          })
          .map((candidate) => ({
            href: `/${candidate.data.lang}/about/`,
            label: LOCALE_INFO[candidate.data.lang].nativeName,
            lang: candidate.data.lang,
          })),
      },
      params: {
        lang: entry.data.lang,
      },
    }));
}) satisfies GetStaticPaths;

const { entry, alternativeLanguageLinks } = Astro.props as Props;
const { Content } = await render(entry);
---

<BlogArticle
  lang={Astro.params.lang}
  title={entry.data.title}
  description={entry.data.excerpt || entry.data.title}
  featureImage={entry.data.featureImage}
  alternativeLanguageLinks={alternativeLanguageLinks}
>
  <Content />
</BlogArticle>
