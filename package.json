{
  "name": "winetree94-com",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project browser",
