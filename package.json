    "@tailwindcss/vite": "4.3.0",
    "astro": "^6.3.3",
    "daisyui": "^5.5.19",
    "remixicon": "^4.9.1",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.12.4",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "vite": "7.3.2",
