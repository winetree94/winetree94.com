{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "./",
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strictNullChecks": true,
    "allowJs": true
  },
  "exclude": [
    "coverage",
    "dist",
    "playwright-report",
    "test-results"
  ]
}
